{
  "patterns": [
    {
      "name": "OpenRouter API Key",
      "pattern": "sk-or-v1-[A-Za-z0-9]{64}",
      "severity": "critical",
      "description": "OpenRouter API key detected"
    },
    {
      "name": "Anthropic API Key",
      "pattern": "sk-ant-api03-[A-Za-z0-9_-]{40,}",
      "severity": "critical",
      "description": "Anthropic Claude API key detected"
    },
    {
      "name": "OpenAI API Key",
      "pattern": "sk-[A-Za-z0-9]{48}",
      "severity": "critical",
      "description": "OpenAI API key detected"
    },
    {
      "name": "Generic Bearer Token",
      "pattern": "Bearer [A-Za-z0-9_-]{20,}",
      "severity": "high",
      "description": "Bearer token detected"
    },
    {
      "name": "AWS Access Key",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "critical",
      "description": "AWS access key detected"
    },
    {
      "name": "GitHub Token",
      "pattern": "ghp_[A-Za-z0-9]{30,}",
      "severity": "critical",
      "description": "GitHub personal access token detected"
    },
    {
      "name": "GitHub Token (classic)",
      "pattern": "gh[pousr]_[A-Za-z0-9]{30,}",
      "severity": "critical",
      "description": "GitHub token detected"
    },
    {
      "name": "Stripe API Key",
      "pattern": "sk_live_[A-Za-z0-9]{24,}",
      "severity": "critical",
      "description": "Stripe live API key detected"
    },
    {
      "name": "Slack Token",
      "pattern": "xox[baprs]-[A-Za-z0-9-]{10,}",
      "severity": "high",
      "description": "Slack token detected"
    },
    {
      "name": "Twitter Bearer",
      "pattern": "AAAAAAAAAAAAAAAAAAAAA[A-Za-z0-9%]{60,}",
      "severity": "high",
      "description": "Twitter bearer token detected"
    },
    {
      "name": "Generic API Key Pattern",
      "pattern": "api[_-]?key[\\s]*[:=][\\s]*['\"]?[A-Za-z0-9_-]{20,}['\"]?",
      "severity": "medium",
      "description": "Generic API key pattern detected",
      "case_insensitive": true
    },
    {
      "name": "Private Key Header",
      "pattern": "-----BEGIN[A-Z ]+PRIVATE KEY-----",
      "severity": "critical",
      "description": "Private key detected"
    },
    {
      "name": "Password in URL",
      "pattern": "://[^:@]+:[^@]+@",
      "severity": "high",
      "description": "Password in URL detected"
    },
    {
      "name": "JWT Token",
      "pattern": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
      "severity": "medium",
      "description": "JWT token detected"
    },
    {
      "name": "Telegram Bot Token",
      "pattern": "[0-9]{8,10}:[A-Za-z0-9_-]{30,}",
      "severity": "critical",
      "description": "Telegram bot token detected"
    },
    {
      "name": "Vercel Token",
      "pattern": "vercel_[A-Za-z0-9]{24}",
      "severity": "high",
      "description": "Vercel token detected"
    },
    {
      "name": "Netlify Token",
      "pattern": "netlify_[A-Za-z0-9_-]{40,}",
      "severity": "high",
      "description": "Netlify token detected"
    },
    {
      "name": "Brave Search API Key",
      "pattern": "BSA[A-Z0-9]{20,}",
      "severity": "high",
      "description": "Brave Search API key detected"
    },
    {
      "name": "Moltbook API Key",
      "pattern": "mb_[A-Za-z0-9]{20,}",
      "severity": "high",
      "description": "Moltbook API key detected"
    }
  ],
  "allowlist": [
    {
      "pattern": "sk-or-v1-example",
      "reason": "Documentation example"
    },
    {
      "pattern": "sk-ant-api03-example",
      "reason": "Documentation example"
    },
    {
      "pattern": "ghp_example",
      "reason": "Documentation example"
    }
  ],
  "metadata": {
